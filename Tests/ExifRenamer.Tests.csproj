<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>7.3</LangVersion>
    <IsPackable>false</IsPackable>
    <RootNamespace>ExifRenamer.Tests</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MSTest" Version="3.8.3" />
  </ItemGroup>

  <!-- The main project uses the legacy csproj format which the dotnet CLI cannot build,
       so the units under test are compiled into the test assembly from source. -->
  <ItemGroup>
    <Compile Include="..\Code\JpegExifRewriter.cs" Link="Sources\JpegExifRewriter.cs" />
    <Compile Include="..\Code\ExifWriterService.cs" Link="Sources\ExifWriterService.cs" />
    <Compile Include="..\Model\ExifEditValues.cs" Link="Sources\ExifEditValues.cs" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="System.Drawing" />
  </ItemGroup>

</Project>
